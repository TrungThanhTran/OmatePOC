# ── LLM Backend ──────────────────────────────────────────────────────────────
# Options: mock | openai | anthropic | ollama
LLM_BACKEND=mock

# ── OpenAI (LLM_BACKEND=openai) ──────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Anthropic (LLM_BACKEND=anthropic) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Ollama (LLM_BACKEND=ollama) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Clinical thresholds ───────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.80
ESCALATION_THRESHOLD=0.90

# ── Triton Inference Server (optional — falls back to local PyTorch) ──────────
TRITON_URL=http://localhost:8000
TRITON_MODEL_ECG=ecg_patchtst
TRITON_MODEL_VERSION=1

# ── MLflow experiment tracking (optional — falls back to in-memory mock) ──────
# MLFLOW_TRACKING_URI=http://localhost:5000
